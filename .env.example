# =============================================================
# Soté — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# =============================================================

# ---------- Privy (identity + embedded wallets) ----------
# Public app ID (safe to expose in the browser bundle)
VITE_PRIVY_APP_ID=cmosl5nnf00uz0dkz3gcqxtlj
# Server-only secret used by /api/privy-bridge to verify access tokens
# Get from https://dashboard.privy.io → your app → Basics
PRIVY_APP_SECRET=replace_me

# ---------- Supabase ----------
# Public — Vite-injected, used by the browser client
VITE_SUPABASE_URL=https://your-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
# Server-side mirrors of the same values (TanStack Start server runtime)
SUPABASE_URL=https://your-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_key
# Server-only — bypasses RLS, used in the bridge route + admin scripts
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Server-only — HS256 secret Supabase uses to verify JWTs
# Get from Supabase dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=ef3db63e-4060-4696-b3c2-805f147865b7

# ---------- Solana / sim-PUSD ----------
VITE_SOLANA_RPC_URL=https://api.devnet.solana.com
# SPL token mint that simulates PUSD on devnet (real PUSD is mainnet-only).
# Generate by running: bun run scripts/create-sim-pusd.ts
VITE_SIM_PUSD_MINT=ADR3QsoUnvSAecGGiFLeJyXtbGsF6iB7dGHizA3c65tR
# Treasury wallet that holds the sim-PUSD supply
VITE_TREASURY_ADDRESS=H6zZAbt9FFZr5CLg3nZUdjFM1ztMPQmjte9V3ezh6Cdz

# ---------- Demo flags ----------
# "true" to show the "Load demo data" button on the dashboard.
# Recommended ON in dev/demo, OFF in production.
VITE_ENABLE_DEMO_SEED=true
# "true" to use the legacy server-side fake-bytes signing path (no real Solana tx).
# Useful when devnet RPC is flaky or you want to demo offline.
VITE_SIMULATE_SIGNING=false
# "true" to mint 50,000 sim-PUSD to a new user's embedded wallet on first login.
# Server-only — only respected by the bridge route.
VITE_AUTOFUND_NEW_WALLETS=true
